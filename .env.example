# Database
MYSQL_HOST=buzzboard-mysql.xxxx.eu-central-1.rds.amazonaws.com
MYSQL_USER=buzzboard
MYSQL_PASSWORD=your-rds-password
MYSQL_DATABASE=buzzboard

# Cache
REDIS_HOST=buzzboard-redis.xxxx.eu-central-1.cache.amazonaws.com
REDIS_PASSWORD=your-redis-auth-token
REDIS_PORT=6379

# App
JWT_SECRET=your-jwt-secret-change-in-production
PORT=8081  # 8081 for reactions, 8082 for mood

# Local development
DATABASE_URL=mysql://buzzboard:buzzboard-secret@localhost:3306/buzzboard